// InstantTeacher - Prisma Schema (Homework help: Sunshine & Jack only)
// PostgreSQL. For local dev: use a free DB at https://neon.tech

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH (Auth.js / NextAuth) ============
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ============ CORE ============
enum Role {
  PARENT
  STUDENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email        String?   @unique
  emailVerified DateTime?
  passwordHash  String?   // for credentials provider
  role         Role
  image        String?
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  banned       Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?   @db.Text

  accounts         Account[]
  sessions         Session[]
  parentProfile    ParentProfile?
  studentProfile   StudentProfile?
  homeworkSessionsRequested HomeworkSession[] @relation("HomeworkRequestedBy")
  subscription Subscription?
}

// ============ PARENT ============
model ParentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  mobile         String
  suburb         String
  emergencyContact String?
  stripeCustomerId String? @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  students StudentProfile[]
}

// ============ STUDENT ============
model StudentProfile {
  id           String   @id @default(cuid())
  parentId     String
  userId       String?  @unique
  fullName     String
  schoolYear   Int      // 3-12
  schoolName   String
  timezone     String   @default("Australia/Perth")
  subjects     String[]
  guardianConsent Boolean?
  streakCurrent  Int      @default(0)
  streakLastActivityDate DateTime?
  examQuestionsCompleted Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent   ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  user     User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  homeworkSessions       HomeworkSession[]
  badges                StudentBadge[]
}

// ============ HOMEWORK HELP (Sunshine / Jack) ============
enum AssistantType {
  SUNSHINE
  JACK
}

enum HomeworkSessionStatus {
  PENDING_PAYMENT
  ACTIVE
  ENDED
  CANCELLED
}

model HomeworkSession {
  id                     String                 @id @default(cuid())
  studentId              String
  requestedByUserId      String
  assistantType          AssistantType
  status                 HomeworkSessionStatus  @default(ACTIVE)
  subject                String?
  sessionType            String                 @default("HOMEWORK") // HOMEWORK | EXAM_PRACTICE
  startedAt              DateTime?
  endsAt                 DateTime?
  stripePaymentIntentId  String?               @unique
  stripeSubscriptionId   String?
  pricePaidCents         Int                    @default(0)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  student     StudentProfile           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedBy User                     @relation("HomeworkRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  messages    HomeworkSessionMessage[]

  @@index([studentId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([endsAt])
}

model HomeworkSessionMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // USER | ASSISTANT
  content   String   @db.Text
  imageUrl  String?  @db.Text
  createdAt DateTime @default(now())

  session HomeworkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum SubscriptionPlan {
  WEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model StudentBadge {
  id        String   @id @default(cuid())
  studentId String
  badgeId   String
  unlockedAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@index([studentId])
}

// Admin-created one-time codes: 7-day Stripe trial on first subscription checkout
model TrialCoupon {
  id             String    @id @default(cuid())
  code           String    @unique // normalized UPPERCASE, no spaces
  referenceNote  String?   @db.Text
  createdAt      DateTime  @default(now())
  usedAt         DateTime?
  usedByUserId   String?

  @@index([code])
  @@index([usedAt])
}
