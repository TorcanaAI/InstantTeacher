# Database (PostgreSQL - Supabase/Neon)
DATABASE_URL="postgresql://user:password@host:5432/instantteacher?schema=public"

# Auth (NextAuth / Auth.js)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Must match the URL users open in the browser (production: https://yourdomain.com). Same as NEXT_PUBLIC_APP_URL is fine.
NEXTAUTH_URL="http://localhost:3000"
# Optional alias for NEXTAUTH_URL (Auth.js v5)
# AUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CONNECT_CLIENT_ID="ca_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Daily.co Video — SERVER ONLY. Domain ≠ API base.
# DAILY_DOMAIN = your subdomain (e.g. instantteacher.daily.co) for room URLs.
# DAILY_API_BASE_URL = always https://api.daily.co/v1 for REST API.
DAILY_API_KEY=""
DAILY_DOMAIN="instantteacher.daily.co"
DAILY_API_BASE_URL="https://api.daily.co/v1"

# Twilio Video (legacy; optional)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_API_KEY="..."
TWILIO_API_SECRET="..."

# Sunshine & Jack (ElevenLabs + OpenAI) — never refer to AI in product
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="hpp4J3VqNfWAUOO0d1Us"
ELEVENLABS_JACK_VOICE_ID=""
OPENAI_API_KEY=""

# Homework subscription (Stripe Price IDs from Dashboard)
STRIPE_PRICE_WEEKLY=""
STRIPE_PRICE_MONTHLY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin: receive email when a teacher registers (Resend)
ADMIN_NOTIFY_EMAIL="admin@example.com"
RESEND_API_KEY="re_..."
# Optional: sender address (must be verified in Resend if custom domain)
# RESEND_FROM="Instant Teacher <notifications@yourdomain.com>"

# Emergency admin bootstrap (temporary – remove once admin login works)
ADMIN_BOOTSTRAP_SECRET="LetMeInNow123!"
